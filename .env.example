# Google OAuth2 credentials (from https://console.cloud.google.com/apis/credentials)
OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_CLIENT_SECRET=your-client-secret

# Generate with: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
OAUTH2_COOKIE_SECRET=random-base64-string

# Path to your media files on the host
MEDIA_DIR=/path/to/your/media

# Timezone
TZ=Europe/Vilnius

# App admin password (for password login, used as fallback)
ADMIN_PASSWORD=changeme

# Comma-separated list of emails that get admin role via OAuth
ADMIN_USERS=admin@example.com

# Optional: comma-separated file/dir names to hide from listing
# FILTERED_FILES=.DS_Store,@eaDir,#snapshot,#recycle,thumbnails

# Optional: comma-separated extensions to hide (without dots)
# HIDDEN_EXTENSIONS=source,srt,db

# Docker image (defaults to ghcr.io/paidem/avm-neo)
# GITHUB_REPOSITORY=your-org/avm-neo
